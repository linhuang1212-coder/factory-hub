# ===== 实例配置：华玥珠宝（外部合作工厂）=====
# 部署目录建议 C:\factory\huayue\ ，本文件复制为该实例 backend\.env

STORE_BASE_URL=https://fblerp.com
STORE_API_KEY=            # 门店侧生成后填(FACTORY_API_KEYS 里"华玥珠宝"那把，与梵贝琳的不同)
FACTORY_SUPPLIER_NAME=华玥珠宝
AUTO_CONFIRM=false        # 合作工厂硬性 false，绝不放开
PUSHED_BY=factory-hub-huayue
DATABASE_URL=sqlite:///./factory_hub.db   # 实例目录内独立文件，与梵贝琳物理隔离
FACTORY_HUB_PORT=8202

FACTORY_AUTH_SECRET=      # 留空自动生成
FACTORY_ADMIN_USER=admin
FACTORY_ADMIN_PASSWORD=   # 留空首启随机生成写 ADMIN_PASSWORD.txt

STYLE_SYNC_ENABLED=false  # ★合作工厂关闭：绝不把电子板房款式库(图/工艺/工费)拉给外厂
