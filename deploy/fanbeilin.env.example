# ===== 实例配置：梵贝琳工厂（自家板房）=====
# 部署目录建议 C:\factory\fanbeilin\ ，本文件复制为该实例 backend\.env

STORE_BASE_URL=https://fblerp.com
STORE_API_KEY=            # 门店侧生成后填(FACTORY_API_KEYS 里"梵贝琳工厂"那把)
FACTORY_SUPPLIER_NAME=梵贝琳工厂
AUTO_CONFIRM=false        # 试点期一律 false，跑顺后自家可评估放开
PUSHED_BY=factory-hub-fanbeilin
DATABASE_URL=sqlite:///./factory_hub.db   # 实例目录内独立文件，与华玥物理隔离
FACTORY_HUB_PORT=8201

FACTORY_AUTH_SECRET=      # 留空自动生成
FACTORY_ADMIN_USER=admin
FACTORY_ADMIN_PASSWORD=   # 留空首启随机生成写 ADMIN_PASSWORD.txt

STYLE_SYNC_ENABLED=true   # 自家工厂：可同步电子板房款式
