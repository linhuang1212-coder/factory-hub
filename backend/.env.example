# ===== FactoryHub 板房发货端配置 =====
# 复制本文件为 .env 并按需修改

# 门店(fblerp)地址。门店端就绪后填实际地址(本机测试可填 http://127.0.0.1:9000)
STORE_BASE_URL=http://127.0.0.1:9000

# 门店发给本工厂的 X-API-Key(对应门店侧 FACTORY_API_KEYS 之一)。
# 留空 = 门店端未就绪，工厂端可正常录单，但"发货"按钮会提示未接通。
STORE_API_KEY=

# 门店认得的本工厂供应商名(发货单默认供应商，须与门店 ERP 的 Supplier.name 一字不差)
FACTORY_SUPPLIER_NAME=梵贝琳工厂

# 是否请求门店自动确认收货(合作工厂必须 false，由门店人工过秤确认)
AUTO_CONFIRM=false

# 推送方标识(落到门店 InboundOrder.pushed_by)
PUSHED_BY=factory-hub

# 本地数据库(每工厂实例独立一个文件，绝不共用)
DATABASE_URL=sqlite:///./factory_hub.db

# 本服务端口
FACTORY_HUB_PORT=8200

# ===== 登录 =====
# 令牌签名密钥(留空=首启自动生成并存 backend/.auth_secret)
FACTORY_AUTH_SECRET=
# 初始管理员(仅 users 表为空时种子一次)
FACTORY_ADMIN_USER=admin
# 留空=首启随机生成并写 backend/ADMIN_PASSWORD.txt(看完请删)
FACTORY_ADMIN_PASSWORD=

# ===== 功能开关 =====
# 款式同步(从门店电子板房拉款式清单)。外部合作工厂实例必须 false，防款式库外泄
STYLE_SYNC_ENABLED=true
